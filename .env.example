APP_NAME=WebTemplate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Use "single,console" in local dev for pretty color-coded terminal logs.
# Use "single" (or "stderr") in production to avoid ANSI codes in log files.
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (MySQL only — no SQLite). Production: standard port 3306.
# Local MAMP: DB_PORT=8889, DB_USERNAME/DB_PASSWORD=root. XAMPP: DB_PORT=3306, root with empty password.
# If MAMP socket connection is needed: DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password
# Backups (spatie/laravel-backup): MAMP keeps mysqldump out of PATH.
# DB_DUMP_BINARY_PATH=/Applications/MAMP/Library/bin/mysql80/bin

# Sessions & Cache - Use file drivers for shared hosting
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

# Full-page response cache (spatie/laravel-responsecache) for static public
# pages. Disable while actively editing content in dev if it gets in the way.
RESPONSE_CACHE_ENABLED=true

# Mail - Configure for production
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Search engine indexing. Keep false for dev/staging so the site is
# kept out of Google (noindex meta + X-Robots-Tag header + blocking
# robots.txt). Set true in production once the site is ready to be found.
SEO_INDEXABLE=false

# Feature Flags
FEATURE_BLOG=true
FEATURE_SHOP=true
FEATURE_CAREERS=false
FEATURE_CASE_STUDIES=false
FEATURE_TEAMS=true
FEATURE_CONTACT_FORM=true

VITE_APP_NAME="${APP_NAME}"
